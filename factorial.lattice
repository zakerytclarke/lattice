// Lattice Factorial Program with Refined Types

// 1. Separate typedef refinement type
type PositiveInteger[Integer](value) {
    value > 0
}

// 2. Function using inline refinement type syntax
function factorial(n: Integer(x){x > 0}) -> Integer {
    if (n <= 1) {
        return 1;
    } else {
        return n * factorial(n-1);
    }
}


function test(n: Integer(x){x > 0}) -> Integer {
    if (n <= 1) {
        return test(100);
    } else 
    if (n == 50) {
        return 1;
    }else{
        return n+test(n-1);
    }
}

