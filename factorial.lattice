function test_works(n: Integer(x){x > 0}) -> Integer {
    if (n <= 1) {
        return test_works(100);
    } else 
    if (n == 50) {
        return 1;
    }else
    if(n > 100){
        return 100;
    }else{
        return n+test_works(n-1);
    }
}


// 4. CLI Entry Point
external function main(n: Integer(x){x > 0}) -> Integer {
    return test_works(n);
}

