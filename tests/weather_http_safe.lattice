// Open-Meteo live weather (no API key): pick a city, GET forecast JSON as a typed struct.
// API docs: https://open-meteo.com/en/docs — we read current.temperature_2m (°F) and return °C.

type CurrentWeather(
    interval: Integer,
    temperature_2m: Integer
)

type WeatherResponse(
    utc_offset_seconds: Integer,
    current: CurrentWeather
)

function fetch_weather(latitude: Rational, longitude: Rational) -> IO[Input[WeatherResponse]] {
    let url: String = "https://api.open-meteo.com/v1/forecast?latitude=" + latitude + "&longitude=" + longitude + "&current=temperature_2m&temperature_unit=fahrenheit";
    let response: Input[WeatherResponse] = http_get(url);
    return response;
}

function convert_fahrenheit_to_celsius(degrees_fahrenheit: Integer) -> Integer {
    return (degrees_fahrenheit - 32) * 5 / 9;
}

external function main(city_arg: Input[String(32)]) {
    let cities = {
        "London": {
            latitude: 51.5,
            longitude: -0.25
        },
        "Paris": {
            latitude: 48.86,
            longitude: 2.35
        },
        "Tokyo": {
            latitude: 35.69,
            longitude: 139.69
        },
        "New York": {
            latitude: 40.71,
            longitude: -74.01
        }
    };

    match (city_arg) { // Check if input is a valid string
        Some(city) => {
            match (cities[city]) { // Chcek if city is in predefined list
                Some(city_coords) => {
                    let weather: Input[WeatherResponse] = fetch_weather(city_coords.latitude, city_coords.longitude);
                    match (weather) { // Check if HTTP response suceeded
                        Some(weather_data) => {
                            let current_temperature = convert_fahrenheit_to_celsius(weather_data.current.temperature_2m);
                            print("The weather in " + city + " is " + current_temperature + " degrees.");
                        }
                        None => {
                            print("Failed to get weather.");
                        }
                    }
                }
                None => {
                    println("City not found.");
                    println("Please provide a city name from the list: " + join(keys(cities), ", "));
                }
            }
        }
        None => {
            print("Invalid Args");
        }
    }
}

