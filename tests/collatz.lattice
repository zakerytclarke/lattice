// The Collatz conjecture says every positive integer eventually reaches 1
// under n → n/2 (even) or n → 3n+1 (odd). That is unproven in general, and
// Lattice rejects this program: the 3n+1 branch does not decrease a provably
// positive argument, so the verifier reports that recursion may not terminate.
//
// Expected: compilation fails with a termination error on the odd branch.
function collatz(n) {
    n > 0;
} {
    if (n == 1) {
        return 0;
    } else {
        if (n % 2 == 0) {
            return 1 + collatz(n / 2);
        } else {
            return 1 + collatz(3 * n + 1);
        }
    }
}

external function main(n_arg: Input[Integer]) {
    match (n_arg) {
        Some(n) => {
            if (n <= 0) {
                return 0;
            } else {
                return collatz(n);
            }
        }
        None => { return 0; }
    }
}
