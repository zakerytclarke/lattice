function add_safe(a: Integer(x){x >= 0 && x <= 50}, b: Integer(y){y >= 0 && y <= 50}) -> Integer(z){z >= 0 && z <= 100} {
    return a + b;
}

function div_safe(a: Rational, b: Rational(x){x.Numerator != 0}) -> Rational {
    return div(a, b);
}

function mixed_math(a: Integer, b: Rational) -> Rational {
    return add(Rational(a, 1), b);
}

external function main(a_arg: Input[Integer], num_arg: Input[Integer], den_arg: Input[Integer]) {
    match (a_arg) {
        Some(a) => {
            match (num_arg) {
                Some(num) => {
                    match (den_arg) {
                        Some(den) => {
                            if (a < 0 || a > 50 || num < 0 || num > 50 || den <= 0 || den > 50) {
                                return 0;
                            } else {
                                const sum = add_safe(a, num);
                                const rat = Rational(num, den);
                                const mixed = mixed_math(a, rat);
                                return sum;
                            }
                        }
                        None => { return 0; }
                    }
                }
                None => { return 0; }
            }
        }
        None => { return 0; }
    }
}
