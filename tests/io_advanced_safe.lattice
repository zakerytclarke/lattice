external function main() {
    let path: String[20] = String(15, List(['t', 'e', 's', 't', 's', '/', 'h', 'e', 'l', 'l', 'o', '.', 't', 'x', 't', 'a', 'b', 'c', 'd', 'e']));
    
    let content_opt: Input[String[20]] = read_file[20, 20](path);
    
    match (content_opt) {
        Some(content) => {
            print_string(content);
            return 1;
        }
        None => {
            return 0;
        }
    }
}
