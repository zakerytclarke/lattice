external function main() {
    let path: String(20) = "tests/hello.txt";
    
    let content_opt: Input[String(20)] = read_file(path);
    
    match (content_opt) {
        Some(content) => {
            print_string(content);
            return 1;
        }
        None => {
            return 0;
        }
    }
}
