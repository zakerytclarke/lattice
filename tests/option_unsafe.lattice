function get_value_unsafe(opt: Input[Integer]) -> Integer {
    match (opt) {
        Some(val) => { return val; }
    }
}

external function main(val_arg: Input[Integer]) {
    match (val_arg) {
        Some(val) => {
            let opt_some: Input[Integer] = Some(val);
            return get_value_unsafe(opt_some);
        }
        None => { return 0; }
    }
}
