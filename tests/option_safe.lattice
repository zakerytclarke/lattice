function get_value_or_default(opt: Input[Integer], default_val: Integer) -> Integer {
    match (opt) {
        Some(val) => { return val; }
        None => { return default_val; }
    }
}

external function main(val_arg: Input[Integer]) {
    match (val_arg) {
        Some(val) => {
            let opt_some: Input[Integer] = Some(val);
            let opt_none: Input[Integer] = None();
            return get_value_or_default(opt_some, 100) + get_value_or_default(opt_none, 100);
        }
        None => { return 0; }
    }
}
