function div_unsafe(a: Rational, b: Rational) -> Rational {
    // Unsafe because b.Numerator could be 0, violating precondition of stdlib div function
    return div(a, b);
}

external function main(a_arg: Input[Integer]) {
    match (a_arg) {
        Some(a) => { return 0; }
        None => { return 0; }
    }
}
