// Load a JSON user table via read_file → Input[List[User]].

type StrSlice(start: Integer, len: Integer)

type User(
    name: StrSlice,
    email: StrSlice,
    phone: StrSlice,
    age: Integer,
    birthdate: StrSlice
)

external function main() {
    let path: String(40) = "tests/sample_users.json";
    let users_opt: Input[List(100)[User]] = read_file(path);
    match (users_opt) {
        Some(users) => {
            return users.data[0].age + users.data[99].age + 100;
        }
        None => {
            return 0;
        }
    }
}
