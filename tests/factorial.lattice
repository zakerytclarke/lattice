function factorial(n: Integer(x){x > 0}) -> Integer {
    if (n == 1) {
        return 1;
    } else {
        return n * factorial(n-1);
    }
}

external function main(n_arg: Input[Integer(x){x > 0}]) {
    match (n_arg) {
        Some(n) => { return factorial(n); }
        None => { return 0; }
    }
}
