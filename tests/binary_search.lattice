// Binary search over a fixed sorted list. The remaining window size `n` is the
// termination measure: every recursive call passes a strictly smaller n.
// The list capacity is annotated so indexing is provably in bounds; everything
// else is inferred.
function binary_search(arr: List(8)[Integer], target, lo, n) {
    n >= 0 && lo >= 0 && lo + n <= 8;
} {
    if (n == 0) {
        return -1;
    } else {
        let mid = lo + n / 2;
        if (arr.data[mid] == target) {
            return mid;
        } else {
            if (arr.data[mid] < target) {
                return binary_search(arr, target, mid + 1, n - n / 2 - 1);
            } else {
                return binary_search(arr, target, lo, n / 2);
            }
        }
    }
}

external function main(target_arg: Input[Integer]) {
    let arr = List([1, 3, 5, 7, 9, 11, 13, 15]);
    match (target_arg) {
        Some(target) => {
            return binary_search(arr, target, 0, 8);
        }
        None => { return 0; }
    }
}
